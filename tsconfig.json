{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./frontend/src/*"
      ],
      "@contracts/*": [
        "./contracts/generated/*"
      ],
      "@sim-shared/*": [
        "./shared/simulator-rules/*"
      ],
      "@backend-contracts/api": [
        "./backend/scripts/shared/api-contract-types.ts"
      ],
      "@backend-contracts/review": [
        "./backend/scripts/shared/review-contract-types.ts"
      ],
      "@backend-persistence": [
        "./backend/scripts/shared/persistence-types.ts"
      ],
      "@backend-provider": [
        "./backend/scripts/shared/provider-types.ts"
      ],
      "@backend-domain": [
        "./backend/scripts/shared/domain-types.ts"
      ],
      "@backend-support/constants": [
        "./backend/scripts/shared/constants.ts"
      ],
      "@backend-support/utils": [
        "./backend/scripts/shared/utils.ts"
      ],
      "@server/*": [
        "./backend/scripts/server/*"
      ]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "backend/scripts/**/*.ts",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "shared/**/*.ts"
  ]
}
