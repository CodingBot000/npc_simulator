{
  "name": "npc-simulator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke:episode": "node scripts/smoke-episode.mjs",
    "collect:episodes": "node scripts/collect-episodes.mjs",
    "replay:eval": "node scripts/replay-eval-cases.mjs",
    "filter:sft": "node scripts/filter-sft-rows.mjs --input data/datasets/sft --output-dir data/evals/filtered",
    "judge:review": "node scripts/judge-review-queue.mjs --mode llm",
    "build:pairs": "node scripts/build-preference-pairs.mjs",
    "review:prepare": "node scripts/prepare-human-review.mjs",
    "finalize:sft": "node scripts/finalize-sft-dataset.mjs",
    "finalize:preference": "node scripts/finalize-preference-dataset.mjs",
    "export:mlx-sft": "node scripts/export-mlx-sft-dataset.mjs",
    "export:mlx-sft:compact": "node scripts/export-mlx-sft-dataset.mjs --output-dir data/train/mlx_sft_compact --input-format compact --assistant-format reply_text",
    "export:mlx-sft:reply": "node scripts/export-mlx-sft-dataset.mjs --output-dir data/train/mlx_sft_reply --input-format compact --assistant-format reply_text",
    "build:mlx-reply50": "node scripts/build-mlx-reply50-dataset.mjs",
    "build:mlx-role-focus": "node scripts/build-mlx-role-focus-dataset.mjs",
    "build:role-replay-cases": "node scripts/build-role-replay-cases.mjs",
    "build:harvested-role-sft": "node scripts/build-harvested-role-sft.mjs",
    "build:role-shortlist": "node scripts/select-role-shortlist.mjs",
    "build:curated-from-shortlist": "node scripts/build-curated-from-shortlist.mjs",
    "generate:sft-augment": "node scripts/generate-synthetic-sft-augment.mjs",
    "generate:curated-role-sft": "node scripts/generate-curated-role-sft.mjs",
    "eval:mlx-reply": "node scripts/eval-mlx-reply.mjs",
    "eval:prepost": "node scripts/eval-prepost.mjs --cases scripts/eval-cases/prepost-benchmark.json --output-dir data/evals/prepost --dry-run",
    "eval:golden:dry": "node scripts/eval-prepost.mjs --cases scripts/eval-cases/reply-golden-v1.json --output-dir data/evals/reply-golden-v1 --dry-run",
    "eval:golden:pairwise:dry": "node scripts/eval-prepost.mjs --cases scripts/eval-cases/reply-golden-v1.json --output-dir data/evals/reply-golden-v1_pairwise_dry --dry-run --pairwise-judge-mode llm"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
