{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ReviewTrainingRunActionRequest",
  "definitions": {
    "ReviewTrainingRunActionRequest": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "bindingKey": {
          "anyOf": [
            {
              "$ref": "#/definitions/ReviewTrainingBindingKey"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "runId"
      ],
      "additionalProperties": false
    },
    "ReviewTrainingBindingKey": {
      "type": "string",
      "enum": [
        "default",
        "doctor",
        "supervisor",
        "director"
      ]
    }
  }
}
