{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ReviewTrainingDecisionRequest",
  "definitions": {
    "ReviewTrainingDecisionRequest": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "decision": {
          "type": "string",
          "enum": [
            "accepted",
            "rejected"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "runId",
        "decision",
        "reviewer",
        "notes"
      ],
      "additionalProperties": false
    }
  }
}
