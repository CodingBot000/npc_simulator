{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SystemInfo",
  "definitions": {
    "SystemInfo": {
      "type": "object",
      "properties": {
        "service": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "pendingMigrations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deploymentMode": {
          "type": "string"
        },
        "database": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string"
            },
            "configured": {
              "type": "boolean"
            },
            "detail": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "configured",
            "detail"
          ],
          "additionalProperties": false
        },
        "provider": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string"
            },
            "configured": {
              "type": "boolean"
            },
            "credentialStatus": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "detail": {
              "type": "string"
            },
            "actionGuide": {
              "type": "string"
            }
          },
          "required": [
            "mode",
            "configured",
            "credentialStatus",
            "label",
            "detail",
            "actionGuide"
          ],
          "additionalProperties": false
        },
        "finalReply": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string"
            },
            "backend": {
              "type": "string"
            },
            "configured": {
              "type": "boolean"
            },
            "credentialStatus": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "detail": {
              "type": "string"
            },
            "actionGuide": {
              "type": "string"
            }
          },
          "required": [
            "mode",
            "backend",
            "configured",
            "credentialStatus",
            "label",
            "detail",
            "actionGuide"
          ],
          "additionalProperties": false
        },
        "reviewAccess": {
          "type": "object",
          "properties": {
            "readable": {
              "type": "boolean"
            },
            "writeMode": {
              "type": "string",
              "enum": [
                "local_unrestricted",
                "admin_token_required"
              ]
            },
            "publicWriteEnabled": {
              "type": "boolean"
            }
          },
          "required": [
            "readable",
            "writeMode",
            "publicWriteEnabled"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "service",
        "status",
        "phase",
        "pendingMigrations",
        "deploymentMode",
        "database",
        "provider",
        "finalReply",
        "reviewAccess"
      ],
      "additionalProperties": false
    }
  }
}
