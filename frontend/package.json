{
  "name": "@npc-simulator/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "node scripts/runtime/static-server.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "browser:install": "npx playwright install chromium",
    "browser:cdp": "bash scripts/browser/start-browser-cdp-mac-v2.sh 9222 http://localhost:3000",
    "browser:cdp:check": "node scripts/browser/check-cdp.mjs --cdp http://127.0.0.1:9222",
    "browser:capture": "node scripts/browser/capture-via-cdp.mjs --cdp http://127.0.0.1:9222 --url http://localhost:3000 --out-dir ../artifacts/cdp-home"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/postcss": "^4",
    "@vitejs/plugin-react": "^5",
    "globals": "^16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^7"
  }
}
