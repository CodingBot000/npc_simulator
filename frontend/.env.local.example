# Frontend local env
#
# Copy to `frontend/.env.local` only when running the Vite frontend directly.
# Leave `VITE_API_BASE_URL` blank to use the Vite dev proxy for a local backend.
# Set it only when the browser should call a remote backend directly.

VITE_API_BASE_URL=
VITE_SHOW_INTERACTION_FAILURE_DEBUG=true
