# Frontend-only env
# Browser-facing backend URL. This must be reachable from the user's browser,
# not just from the container network.
# Local browser -> local backend:
VITE_API_BASE_URL=http://localhost:8080
# Local browser -> cloud backend, or cloud frontend -> cloud backend:
# VITE_API_BASE_URL=https://api.example.com
# Static CDN deployment:
# - If the app is served from S3/CloudFront without the provided Node static
#   server, set VITE_API_BASE_URL during build or upload a generated
#   env-config.js next to the built assets.
# - The value must be reachable from the end user's browser.
# VITE_API_BASE_URL=https://api.your-domain.example

# Show per-turn failure debug blocks in the conversation UI.
# Set to false to hide without removing the code path.
VITE_SHOW_INTERACTION_FAILURE_DEBUG=true

# Do not put DB, LLM, or provider secrets in frontend env files.
