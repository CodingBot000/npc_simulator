# Backend production env
#
# Use as platform env/secret-manager reference for separated backend deploys.
# Do not commit real secrets.

NPC_SIMULATOR_DEPLOYMENT_MODE=cloud
BACKEND_PORT=8080
BACKEND_STORAGE_ROOT=/srv/npc-simulator/storage
SPRING_PROFILES_ACTIVE=prod

# Managed database
SPRING_DATASOURCE_URL=jdbc:postgresql://db.example.internal:5432/npc_simulator
SPRING_DATASOURCE_USERNAME=npc_simulator
SPRING_DATASOURCE_PASSWORD=replace_me

# Runtime bridge / container layout
NPC_SIMULATOR_ROOT=/workspace
NPC_SIMULATOR_WORKDIR=/workspace
NPC_SIMULATOR_SCRIPTS_ROOT=/workspace/backend/scripts
NPC_SIMULATOR_NODE_BIN_DIR=/workspace/node_modules/.bin
NPC_SIMULATOR_DATA_ROOT=/workspace/data
NPC_SIMULATOR_OUTPUTS_ROOT=/workspace/outputs
NPC_SIMULATOR_BRIDGE_ENABLED=true
NPC_SIMULATOR_BRIDGE_TIMEOUT_SECONDS=420
NPC_SIMULATOR_CORS_ALLOWED_ORIGINS=https://app.example.com
NPC_SIMULATOR_ADMIN_TOKEN=replace_me_for_private_admin_calls

# Structured interaction provider
LLM_PROVIDER_MODE=openai
INTERACTION_MODEL=gpt-4.1-nano
INTERACTION_FALLBACK_MODEL=gpt-4.1-mini
INTERACTION_JUDGE_MODE=off
INTERACTION_JUDGE_MODEL=gpt-4.1-nano
INTERACTION_JUDGE_TIMEOUT_MS=8000
INTERACTION_JUDGE_MAX_OUTPUT_TOKENS=96
INTERACTION_JUDGE_ENFORCEMENT=off
INTERACTION_JUDGE_CONFIDENCE_THRESHOLD=0.8

# Evaluation / model aliases
EVAL_MODEL=gpt-5.4
EVAL_FALLBACK_MODEL=gpt-4.1-nano
OPENAI_MODEL=gpt-5.4
LOW_COST_MODEL=gpt-5.4-mini
PREMIUM_MODEL=gpt-5.4
LOW_COST_FALLBACK_MODEL=gpt-5.4-mini
PREMIUM_FALLBACK_MODEL=gpt-5.4-mini

# Secrets. Prefer platform secret injection.
OPENAI_API_KEY=replace_me
TOGETHER_API_KEY=
RUNPOD_API_KEY=
BASETEN_API_KEY=
HF_TOKEN=

# Final reply backend baseline. Keep off unless hosted rewrite is configured.
FINAL_REPLY_MODE=off
FINAL_REPLY_BACKEND=off
FINAL_REPLY_MODEL=
FINAL_REPLY_FALLBACK_MODEL=
FINAL_REPLY_MAX_TOKENS=160
FINAL_REPLY_PROMPT_FORMAT=scene_state_min
FINAL_REPLY_REMOTE_PROVIDER=
FINAL_REPLY_REMOTE_MODEL_NAME=
FINAL_REPLY_RUNPOD_ENDPOINT_ID=
FINAL_REPLY_BASETEN_MODEL_ID=
FINAL_REPLY_BASETEN_MODEL_URL=
FINAL_REPLY_USE_PROMOTED=false

# Optional Baseten final reply example:
# FINAL_REPLY_MODE=on
# FINAL_REPLY_BACKEND=baseten
# FINAL_REPLY_REMOTE_MODEL_NAME=npc-sim-manual-llama31-local-check-20260421-025259
# FINAL_REPLY_BASETEN_MODEL_ID=replace_model_id
# FINAL_REPLY_BASETEN_MODEL_URL=https://model-xxxx.api.baseten.co/environments/production/sync/v1
# BASETEN_API_KEY=replace_me

# Optional RunPod final reply example:
# FINAL_REPLY_MODE=on
# FINAL_REPLY_BACKEND=runpod
# FINAL_REPLY_REMOTE_PROVIDER=runpod:replace_endpoint_id
# FINAL_REPLY_REMOTE_MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct
# FINAL_REPLY_RUNPOD_ENDPOINT_ID=replace_endpoint_id
# RUNPOD_API_KEY=replace_me

# Local artifact/runtime values remain disabled by default in cloud.
CANONICAL_MODEL_FAMILY=llama31_8b_instruct
LOCAL_REPLY_ADAPTER_MODE=off
LOCAL_REPLY_MODEL_FAMILY=llama
LOCAL_REPLY_USE_PROMOTED=false
LOCAL_REPLY_MAX_TOKENS=160
LOCAL_REPLY_LLAMA_RUNTIME_PATH=outputs/training/manual_llama31_local_check_20260421_025259/runtime
LOCAL_REPLY_LLAMA_PROMPT_FORMAT=scene_state_min
SHADOW_COMPARE_ENABLED=false
SHADOW_COMPARE_LABEL="Local Llama Shadow"
SHADOW_COMPARE_RUNTIME_ARTIFACT_PATH=outputs/training/manual_llama31_local_check_20260421_025259/runtime
SHADOW_COMPARE_RUNTIME_ARTIFACT_KIND=mlx_fused_model
SHADOW_COMPARE_MLX_MODEL=
SHADOW_COMPARE_MAX_TOKENS=360
NPC_AUTONOMY_DEBUG_SEED=
