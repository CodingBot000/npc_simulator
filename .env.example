# Local compose umbrella env.
# This file is for single-machine local/docker runs.
# For separated cloud deploys, use frontend/.env.example and backend/.env.example
# as the actual ownership guides for each deployment unit.

# Local ports
FRONTEND_HOST_PORT=3000
FRONTEND_DEV_PORT=3000
BACKEND_HOST_PORT=8080
BACKEND_PORT=8080

# Backend storage / profile
BACKEND_STORAGE_ROOT=/srv/npc-simulator/storage
SPRING_PROFILES_ACTIVE=local

# Local database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/npc_simulator
SPRING_DATASOURCE_USERNAME=npc_simulator
SPRING_DATASOURCE_PASSWORD=npc_simulator
POSTGRES_DB=npc_simulator
POSTGRES_USER=npc_simulator
POSTGRES_PASSWORD=npc_simulator
POSTGRES_PORT=5432

# Frontend public API config
# Local default:
VITE_API_BASE_URL=http://localhost:8080
# Separated cloud deploy example:
# VITE_API_BASE_URL=https://api.example.com

# Backend runtime / CORS
NPC_SIMULATOR_ROOT=.
NPC_SIMULATOR_WORKDIR=.
NPC_SIMULATOR_SCRIPTS_ROOT=./backend/scripts
NPC_SIMULATOR_NODE_BIN_DIR=./node_modules/.bin
NPC_SIMULATOR_DATA_ROOT=./data
NPC_SIMULATOR_OUTPUTS_ROOT=./outputs
NPC_SIMULATOR_BRIDGE_ENABLED=true
NPC_SIMULATOR_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# If a local browser talks to a cloud backend, include localhost here too:
# NPC_SIMULATOR_CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000,http://127.0.0.1:3000

# Backend LLM config
# Local default uses Codex CLI. For cloud backend, prefer a server-side provider
# such as openai and inject secrets at deploy time.
LLM_PROVIDER_MODE=codex
LOCAL_REPLY_ADAPTER_MODE=off
LOCAL_REPLY_MODEL_FAMILY=llama
LOCAL_REPLY_USE_PROMOTED=false
LOCAL_REPLY_LLAMA_RUNTIME_PATH=outputs/training/manual_llama31_local_check_20260421_025259/runtime
LOCAL_REPLY_LLAMA_PROMPT_FORMAT=scene_state_min
SHADOW_COMPARE_ENABLED=false
SHADOW_COMPARE_LABEL="Local Llama Shadow"
SHADOW_COMPARE_RUNTIME_ARTIFACT_PATH=outputs/training/manual_llama31_local_check_20260421_025259/runtime
SHADOW_COMPARE_RUNTIME_ARTIFACT_KIND=mlx_fused_model
SHADOW_COMPARE_MLX_MODEL=mlx-community/Llama-3.1-8B-Instruct-4bit
SHADOW_COMPARE_MAX_TOKENS=360
NPC_AUTONOMY_DEBUG_SEED=
INTERACTION_MODEL=gpt-4.1-nano
INTERACTION_FALLBACK_MODEL=gpt-4.1-mini
EVAL_MODEL=gpt-5.4
EVAL_FALLBACK_MODEL=gpt-4.1-nano
OPENAI_MODEL=gpt-5.4
LOW_COST_MODEL=gpt-5.4-mini
PREMIUM_MODEL=gpt-5.4
LOW_COST_FALLBACK_MODEL=gpt-5.4-mini
PREMIUM_FALLBACK_MODEL=gpt-5.4-mini
# OPENAI_API_KEY=
